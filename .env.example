# ── Binance ──────────────────────────────────────────────
BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here
BINANCE_TESTNET=true          # set false for live

# ── FundedTraderMarkets ───────────────────────────────────
FTM_API_KEY=your_key_here
FTM_API_URL=https://api.fundedtradermarkets.com   # confirm with their docs
FTM_ACCOUNT_ID=your_account_id

# ── Risk ─────────────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0        # % of balance risked per trade
MAX_OPEN_TRADES=3             # across all brokers combined
MAX_DAILY_DRAWDOWN_PCT=4.0    # halt trading if daily loss exceeds this
MAX_TOTAL_DRAWDOWN_PCT=8.0    # prop firm hard limit — adjust to your rules

# ── Bot ──────────────────────────────────────────────────
ACTIVE_BROKER=binance         # binance | ftm | both
LOG_LEVEL=INFO
LEDGER_PATH=logs/ledger.jsonl
